{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "Agent"
    ],
    "deny": [
      "Bash(php artisan migrate:fresh*)",
      "Bash(php artisan db:wipe*)",
      "Bash(make fresh*)",
      "Bash(make initdb*)",
      "Bash(dropdb*)",
      "Bash(psql* DROP DATABASE*)"
    ]
  }
}
